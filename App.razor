@* App.razor — root of the Blazor component tree *@
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            @* AuthorizeRouteView enforces [Authorize] attributes on pages *@
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @* Unauthenticated users attempting protected pages land here *@
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="page-wrapper" style="text-align:center;padding:4rem 1rem;">
                    <h1>Page not found</h1>
                    <p>The page you requested could not be found.</p>
                    <a href="/calculator" class="btn-primary" style="display:inline-block;margin-top:1.5rem;">
                        Go to calculator
                    </a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
