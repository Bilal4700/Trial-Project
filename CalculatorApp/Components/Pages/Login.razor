@page "/login"
@using System.ComponentModel.DataAnnotations
@inject AuthService AuthService
@inject SessionStateService SessionState
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Login - Raptor Trial</PageTitle>

<section class="auth-screen">
    <div class="auth-card">
        <div class="section-kicker">Raptor Trial</div>
        <h1>@(_isRegistering ? "Create an account" : "Sign in")</h1>
        <p class="muted-text">
            Use the backend authentication service to validate credentials and log each attempt.
        </p>

        <EditForm Model="@_model" OnValidSubmit="@SubmitAsync" FormName="login-form">
            <DataAnnotationsValidator />

            <div class="field-stack">
                <label for="username">Username</label>
                <input id="username"
                       class="raptor-input"
                       @bind="_model.Username"
                       @bind:event="oninput"
                       autocomplete="username" />
                <ValidationMessage For="@(() => _model.Username)" />
            </div>

            <div class="field-stack">
                <label for="password">Password</label>
                <input id="password"
                       class="raptor-input"
                       type="password"
                       @bind="_model.Password"
                       @bind:event="oninput"
                       autocomplete="@(_isRegistering ? "new-password" : "current-password")" />
                <ValidationMessage For="@(() => _model.Password)" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="@_messageClass" role="status">@_message</div>
            }

            <button class="raptor-primary-button" type="submit" disabled="@_isBusy">
                @if (_isBusy)
                {
                    <span>Working...</span>
                }
                else
                {
                    <span>@(_isRegistering ? "Create account" : "Sign in")</span>
                }
            </button>
        </EditForm>

        <button class="raptor-secondary-button" type="button" @onclick="ToggleMode">
            @(_isRegistering ? "Back to sign in" : "Need an account?")
        </button>
    </div>
</section>

@code {
    private readonly LoginInput _model = new();
    private bool _isBusy;
    private bool _isRegistering;
    private string _message = string.Empty;
    private string _messageClass = "raptor-alert";

    protected override void OnInitialized()
    {
        if (SessionState.IsLoggedIn)
        {
            Navigation.NavigateTo("/calculator");
        }
    }

    private async Task SubmitAsync()
    {
        _isBusy = true;
        _message = string.Empty;

        try
        {
            var result = _isRegistering
                ? await AuthService.RegisterAsync(_model.Username, _model.Password)
                : await AuthService.LoginAsync(_model.Username, _model.Password);

            if (!result.IsSuccess)
            {
                _messageClass = "raptor-alert raptor-alert-error";
                _message = result.Message;
                return;
            }

            if (_isRegistering)
            {
                Logger.LogInformation("Frontend registered user {Username}.", result.Username);
                _messageClass = "raptor-alert raptor-alert-success";
                _message = "Account created. You can sign in now.";
                _isRegistering = false;
                _model.Password = string.Empty;
                return;
            }

            Logger.LogInformation("Frontend login succeeded for {Username}.", result.Username);
            Navigation.NavigateTo("/calculator");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ToggleMode()
    {
        _isRegistering = !_isRegistering;
        _message = string.Empty;
        _model.Password = string.Empty;
    }

    private sealed class LoginInput
    {
        [Required(ErrorMessage = "Username is required.")]
        [StringLength(50, ErrorMessage = "Username cannot be longer than 50 characters.")]
        public string? Username { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(50, MinimumLength = 4, ErrorMessage = "Password must be 4 to 50 characters.")]
        public string? Password { get; set; }
    }
}
